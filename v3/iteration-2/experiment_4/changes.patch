+            2. While restore is in progress, check for VirtualMachineInstance existence
+
+        Expected:
+            - No VirtualMachineInstance exists for the VM during restore
+        """
+        vm_for_test, snapshot = rerun_on_failure_vm_with_snapshot
+        LOGGER.info(f"Restoring VM {vm_for_test.name} and checking no VMI is auto-started")
+        with VirtualMachineRestore(
+            client=admin_client,
+            name=f"restore-autostart-{vm_for_test.name}",
+            namespace=vm_for_test.namespace,
+            vm_name=vm_for_test.name,
+            snapshot_name=snapshot.name,
+        ) as vm_restore:
+            for sample in TimeoutSampler(
+                wait_timeout=TIMEOUT_5MIN,
+                sleep=TIMEOUT_5SEC,
+                func=lambda: vm_restore.instance.get("status", {}).get("complete"),
