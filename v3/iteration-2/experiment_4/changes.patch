+class TestSnapshotRestoreDataIntegrity:
+    """
+    End-to-end tests for snapshot restore data integrity with RerunOnFailure.
+
+    Validates that snapshot restore correctly preserves pre-snapshot data
+    and removes post-snapshot data.
+    """
+
+    @pytest.mark.jira("CNV-63819")
+    def test_preserves_pre_snapshot_data(
+        self,
+        data_integrity_restored_vm,
+    ):
+        """
+        Test that files created before a snapshot are preserved after restore.
+
+        Steps:
+            1. Read file original.txt from the restored VM
+
+        Expected:
+            - File content equals "data-before-snapshot"
+        """
+        LOGGER.info(f"Checking pre-snapshot file content on VM {data_integrity_restored_vm.name}")
+        result = run_ssh_commands(
+            host=data_integrity_restored_vm.ssh_exec,
+            commands=shlex.split("cat original.txt"),
+        )
+        file_content = result[0].strip()
+        assert file_content == "data-before-snapshot", (
+            f"Pre-snapshot file content '{file_content}' does not equal 'data-before-snapshot'"
+        )
+
+    @pytest.mark.jira("CNV-63819")
+    def test_removes_post_snapshot_data(
+        self,
+        data_integrity_restored_vm,
+    ):
+        """
+        Test that files created after a snapshot are removed after restore.
+
+        Steps:
+            1. Check if file after.txt exists on the restored VM
+
+        Expected:
+            - File after.txt does NOT exist
+        """
+        LOGGER.info(f"Checking post-snapshot file absence on VM {data_integrity_restored_vm.name}")
+        result = run_ssh_commands(
+            host=data_integrity_restored_vm.ssh_exec,
+            commands=shlex.split("test -f after.txt && echo exists || echo missing"),
+        )
+        assert result[0].strip() == "missing", (
+            "File after.txt should NOT exist after restore but was found"
+        )
